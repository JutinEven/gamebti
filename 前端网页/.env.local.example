# ============================================
# Gamebti Web Companion - 环境变量配置
# ============================================
# 复制此文件为 .env.local 并填入实际值
# cp .env.local.example .env.local
# ============================================

# Coze API 配置
# 从 Coze 控制台获取: https://www.coze.com/open/api
COZE_API_KEY=your_coze_api_key_here
COZE_BOT_ID=your_coze_bot_id_here

# Coze API 请求地址 (默认国际版, 国内版请用 https://api.coze.cn)
COZE_API_BASE_URL=https://api.coze.com

# 请求超时时间 (毫秒)
COZE_API_TIMEOUT=30000

# ---- 后端提供商选择 ----
# 可选值: agent (自部署Agent后端) | coze (Coze API)
AGENT_PROVIDER=agent

# ---- 自部署 Agent 后端配置 (AGENT_PROVIDER=agent 时生效) ----
# Agent 后端服务地址
AGENT_BASE_URL=http://localhost:5000

# Agent 请求超时（毫秒），Agent 推理可能需要较长时间
AGENT_TIMEOUT=120000

# ---- 开发调试 ----
# 设为 true 启用模拟模式（无需 Agent/Coze，使用内置模拟回复）
# COZE_MOCK_MODE=true
