# Gamebti Agent 环境配置模板
# 复制此文件为 .env 并填入你的 Key

# LLM 提供商: zhipu | doubao | qwen | deepseek | openai
LLM_PROVIDER=qwen
LLM_API_KEY=your_api_key_here
LLM_MODEL=qwen-plus

# IsThereAnyDeal API (免费申请: https://isthereanydeal.com/apps/)
ITAD_API_KEY=your_itad_key_here

# PostgreSQL (可选，不配置则使用内存模式)
# PGDATABASE_URL=postgresql://user:pass@host:5432/dbname
